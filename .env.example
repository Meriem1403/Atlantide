# ── Frontend (Vite / Netlify) ────────────────────────────────────────────────
# URL complète de l'API, suffixe /api inclus.
# Ex. production : https://api.mondomaine.fr/api
# En dev local (proxy Vite) : laisser vide ou /api
VITE_API_URL=

# ── Base de données ──────────────────────────────────────────────────────────
DB_NAME=ticketsrepas
DB_USER=ticketsrepas
DB_PASSWORD=ticketsrepas

# Backend
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Production
FRONTEND_PORT=80

# Email (Mailpit en dev : http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=Tickets Repas <noreply@ticketsrepas.local>
ADMIN_NOTIFICATION_EMAIL=compta@mairie.fr
MAIL_ENABLED=true
